{
  "$schema": "../gen/schemas/desktop-schema.json",
  "productName": "Typeoff",
  "identifier": "com.typeoff.app",
  "version": "0.2.0",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Typeoff",
        "width": 440,
        "height": 520,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true,
        "acceptFirstMouse": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
